{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "ollim-bot",
  "colors": {
    "primary": "#5865F2",
    "light": "#7289DA",
    "dark": "#4752C4"
  },
  "favicon": "/images/favicon.png",
  "logo": {
    "light": "/images/logo.png",
    "dark": "/images/logo.png",
    "href": "https://github.com/Ollim-AI/ollim-bot"
  },
  "navbar": {
    "links": [
      {
        "label": "GitHub",
        "href": "https://github.com/Ollim-AI/ollim-bot"
      }
    ]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/Ollim-AI/ollim-bot"
    }
  },
  "seo": {
    "metatags": {
      "og:site_name": "ollim-bot",
      "og:image": "https://docs.ollim.ai/images/logo.png",
      "twitter:card": "summary"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "claude",
      "chatgpt",
      "mcp"
    ]
  },
  "redirects": [
    {
      "source": "/getting-started/how-it-works",
      "destination": "/architecture/how-it-works"
    },
    {
      "source": "/getting-started/design-philosophy",
      "destination": "/architecture/design-philosophy"
    }
  ],
  "navigation": {
    "tabs": [
      {
        "tab": "Guide",
        "pages": [
          "getting-started/overview",
          "getting-started/quickstart",
          "getting-started/setup",
          {
            "group": "Using the Bot",
            "icon": "message-bot",
            "pages": [
              "core-usage/conversations",
              "core-usage/slash-commands",
              "core-usage/forks",
              "core-usage/embeds-and-buttons",
              "core-usage/permissions"
            ]
          },
          {
            "group": "Scheduling",
            "icon": "clock",
            "root": "scheduling/overview",
            "pages": [
              "scheduling/routines",
              "scheduling/reminders",
              "scheduling/background-forks",
              "scheduling/ping-budget",
              "scheduling/examples"
            ]
          },
          {
            "group": "Integrations",
            "icon": "plug",
            "root": "integrations/google-overview",
            "pages": [
              "integrations/google-tasks",
              "integrations/google-calendar",
              "integrations/google-gmail",
              "integrations/webhooks"
            ]
          }
        ]
      },
      {
        "tab": "Customizing",
        "groups": [
          {
            "group": "Extending",
            "icon": "puzzle-piece",
            "root": "extending/overview",
            "pages": [
              "extending/mcp-tools",
              "extending/subagents",
              "extending/system-prompt",
              "extending/adding-integrations"
            ]
          },
          {
            "group": "Self-Hosting",
            "icon": "server",
            "pages": [
              "self-hosting/guide",
              "self-hosting/discord-bot-setup",
              "self-hosting/google-oauth-setup",
              "self-hosting/model-providers"
            ]
          }
        ]
      },
      {
        "tab": "Reference",
        "groups": [
          {
            "group": "Configuration",
            "icon": "gear",
            "pages": [
              "configuration/reference",
              "configuration/data-directory",
              "configuration/file-formats"
            ]
          },
          {
            "group": "Concepts",
            "icon": "sitemap",
            "root": "architecture/overview",
            "pages": [
              "architecture/design-philosophy",
              "architecture/how-it-works",
              "architecture/session-management",
              "architecture/context-flow",
              "architecture/streaming"
            ]
          },
          {
            "group": "Development",
            "icon": "code",
            "pages": [
              "development/guide",
              "development/testing",
              "development/cli-reference",
              "development/troubleshooting"
            ]
          }
        ]
      }
    ],
    "anchors": [
      {
        "anchor": "Changelog",
        "icon": "clock-rotate-left",
        "pages": [
          "changelog"
        ]
      }
    ]
  }
}
